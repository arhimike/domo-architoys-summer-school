---
layout: layouts/base.njk
pageType: day
bodyClass: article-page
---
<article>
  <header class="day-hero section-grid">
    <nav class="breadcrumbs mono" aria-label="Хлебные крошки"><a href="/">Дневник</a><span>/</span><span>День {{ day_number }}</span></nav>
    <div class="day-index" aria-hidden="true"><b>{{ day_number }}</b><span>/10</span></div>
    <div class="day-title-block">
      <p class="eyebrow"><time datetime="{{ date | dateIso }}">{{ date | dateRu }} 2026</time> · {{ location }}</p>
      <h1>{{ title }}</h1>
      <p class="day-deck">{{ deck }}</p>
    </div>
    <dl class="day-meta mono">
      <div><dt>Площадка</dt><dd>{{ venue }}</dd></div>
      <div><dt>Адрес</dt><dd>{{ address }}</dd></div>
      <div><dt>Формат</dt><dd>{{ event_format }}</dd></div>
      <div><dt>Куратор</dt><dd><a href="{{ site.mainSite }}">{{ site.author }}</a></dd></div>
    </dl>
    {% if cover_image %}
      <figure class="day-cover">
        <img src="{{ cover_image }}" alt="{{ cover_alt }}" fetchpriority="high" decoding="async">
        {% if cover_caption %}<figcaption><span class="mono">Обложка</span> {{ cover_caption }}</figcaption>{% endif %}
      </figure>
    {% endif %}
  </header>

  {% if summary_steps %}
    <section class="day-summary section-grid ruled-section" aria-label="Краткая структура дня">
      <div class="section-label mono">День в трёх частях</div>
      <ol class="summary-steps">
        {% for step in summary_steps %}
          <li><span class="mono">{{ loop.index | roman }}</span><h3>{{ step.title }}</h3><p>{{ step.text }}</p></li>
        {% endfor %}
      </ol>
    </section>
  {% endif %}

  {% if lecture_title or lecture_body %}
    <section class="article-section section-grid" aria-labelledby="lecture-title">
      <div class="section-label mono">Вступление / 01</div>
      <div class="article-heading">
        <p class="eyebrow">{{ lecture_eyebrow }}</p>
        <h2 id="lecture-title">{{ lecture_title }}</h2>
      </div>
      <div class="article-copy prose">{{ lecture_body | markdown | safe }}</div>
    </section>
  {% endif %}

  {% if discussion_title or discussion_body %}
    <section class="debate-section section-grid" aria-labelledby="discussion-title">
      <div class="section-label mono">Дискуссия / 02</div>
      <div class="debate-title-block">
        <p class="eyebrow">Разговор в группе</p>
        <h2 id="discussion-title">{{ discussion_title }}</h2>
      </div>
      {% if discussion_lead %}<p class="debate-lead">{{ discussion_lead }}</p>{% endif %}
      <div class="debate-body prose">{{ discussion_body | markdown | safe }}</div>
    </section>
  {% endif %}

  {% if projects %}
    <section class="projects-section section-grid" id="projects" aria-labelledby="projects-title">
      <div class="section-label mono">Проекты / 03</div>
      <div class="section-heading projects-heading">
        <p class="eyebrow">Идеи, сформулированные в этот день</p>
        <h2 id="projects-title">{{ projects_title or 'Проектные направления' }}</h2>
        {% if projects_intro %}<p>{{ projects_intro }}</p>{% endif %}
      </div>
      <div class="projects-grid">
        {% for project in projects %}
          <article class="project-card{% if loop.first %} project-card-featured{% endif %}{% if project.dark %} project-card-dark{% endif %}{% if loop.last and projects.length % 2 == 1 %} project-card-wide{% endif %}">
            <div class="project-top"><span class="project-no">{{ loop.index | pad2 }}</span><span class="project-author mono">{{ project.author }}</span></div>
            <h3>{{ project.title }}</h3>
            <p>{{ project.description }}</p>
            {% if project.tags %}<ul>{% for tag in project.tags %}<li>{{ tag }}</li>{% endfor %}</ul>{% endif %}
            {% if project.note %}<small>{{ project.note }}</small>{% endif %}
          </article>
        {% endfor %}
      </div>
    </section>
  {% endif %}

  {% if results_body or outcomes.length %}
    <section class="outcomes-section section-grid ruled-section" aria-labelledby="outcomes-title">
      <div class="section-label mono">Итоги / 04</div>
      <div class="outcomes-heading">
        <p class="eyebrow">Что зафиксировали к завершению</p>
        <h2 id="outcomes-title">{{ results_title }}</h2>
      </div>
      <div class="results-body prose">{{ results_body | markdown | safe }}</div>
      {% if outcomes %}
        <ol class="outcomes-list">
          {% for outcome in outcomes %}<li><span>{{ loop.index | pad2 }}</span><p>{{ outcome }}</p></li>{% endfor %}
        </ol>
      {% endif %}
    </section>
  {% endif %}

  {% if short_post %}
    <section class="short-post section-grid" aria-labelledby="post-title">
      <div class="section-label mono">Короткий пост / 05</div>
      <div class="post-heading">
        <p class="eyebrow">Версия для публикации</p>
        <h2 id="post-title">День {{ day_number }} — коротко</h2>
        <button class="button copy-button" type="button" data-copy-target="#post-source"><span>Скопировать текст</span></button>
      </div>
      <div class="post-text" id="post-source">{{ short_post | markdown | safe }}</div>
    </section>
  {% endif %}

  {% set visibleGallery = gallery | visiblePhotos %}
  {% if visibleGallery.length %}
    <section class="photos-section" id="photos" aria-labelledby="photos-title">
      <div class="section-grid photos-heading">
        <div class="section-label mono">Фотоотчёт / 06</div>
        <div><p class="eyebrow">{{ date | dateRu }} 2026</p><h2 id="photos-title">День в кадрах</h2></div>
      </div>
      <div class="photo-grid" data-gallery>
        {% for photo in visibleGallery %}
          <figure class="photo-item{% if photo.layout == 'wide' %} photo-wide{% elseif photo.layout == 'tall' %} photo-tall{% endif %}">
            <a class="photo-button" href="{{ photo.image }}" data-full="{{ photo.image }}" data-caption="{{ photo.caption }}">
              <img src="{{ photo.image }}" alt="{{ photo.alt }}" loading="eager" decoding="async">
              <span class="zoom-hint" aria-hidden="true">↗</span>
            </a>
            <figcaption><span class="mono">{{ loop.index | pad2 }}</span> {{ photo.caption }}</figcaption>
          </figure>
        {% endfor %}
      </div>
    </section>
  {% endif %}

  <footer class="article-footer section-grid">
    {% set dayNav = collections.days | dayNavigation(day_number) %}
    <nav class="day-navigation" aria-label="Навигация по дням">
      {% if dayNav.previous %}
        <a href="/{{ dayNav.previous.slug }}/"><span class="mono">← День {{ dayNav.previous.day_number }}</span><b>{{ dayNav.previous.card_title or dayNav.previous.title }}</b></a>
      {% else %}
        <a href="/"><span class="mono">← Архив</span><b>Все дни школы</b></a>
      {% endif %}
      {% if dayNav.next %}
        <a href="/{{ dayNav.next.slug }}/"><span class="mono">День {{ dayNav.next.day_number }} →</span><b>{{ dayNav.next.card_title or dayNav.next.title }}</b></a>
      {% else %}
        <span aria-disabled="true"><span class="mono">Следующий день</span><b>Скоро</b></span>
      {% endif %}
    </nav>
  </footer>
</article>

{% if visibleGallery.length %}
  <dialog class="lightbox" data-lightbox aria-label="Просмотр фотографии" aria-modal="true">
    <button class="lightbox-close" type="button" data-lightbox-close aria-label="Закрыть">×</button>
    <button class="lightbox-prev" type="button" data-lightbox-prev aria-label="Предыдущая фотография">←</button>
    <figure><img src="{{ visibleGallery[0].image }}" alt="{{ visibleGallery[0].alt }}" decoding="async"><figcaption></figcaption></figure>
    <button class="lightbox-next" type="button" data-lightbox-next aria-label="Следующая фотография">→</button>
    <div class="lightbox-status" data-lightbox-status role="status" aria-live="polite">
      <span>Загрузка фотографии…</span>
      <a href="{{ visibleGallery[0].image }}" target="_blank" rel="noopener" data-lightbox-fallback>Открыть файл отдельно ↗</a>
    </div>
  </dialog>
{% endif %}
